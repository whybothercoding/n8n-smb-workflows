    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst parsed = $input.first().json;\nconst so = parsed.subject_options || ['', '', ''];\nconst si = parsed.signal_items || [];\nconst theme = parsed.theme || '';\nconst guid = crypto.randomUUID();\nconst pubDate = new Date().toISOString();\nconst slackMessage = `\ud83d\udcdd *StackSignal draft queued in RSS feed*\\n\\n*Theme:* ${theme}\\n\\n*Subject options:*\\n1. ${so[0]}\\n2. ${so[1]}\\n3. ${so[2]}\\n\\n*Signal items:* ${si.length} pre-populated\\n\\n\u2192 Beehiiv picks it up within the hour. Open Beehiiv to write Workflow + Stack Move sections.`;\nreturn [{ json: { ...parsed, rss_guid: guid, rss_pub_date: pubDate, rss_title: parsed.beehiivTitle, rss_body_html: parsed.beehiivContent, slackMessage } }];"
      },
