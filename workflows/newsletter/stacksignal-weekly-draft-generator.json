    {
      "parameters": {
        "jsCode": "const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\nconst filtered = $input.all()\n  .filter(item => {\n    const d = new Date(item.json.pubDate || item.json.isoDate || 0);\n    return !isNaN(d.getTime()) && d > sevenDaysAgo;\n  })\n  .map(item => ({\n    title: String(item.json.title || '').trim(),\n    link: String(item.json.link || ''),\n    contentSnippet: String(item.json.contentSnippet || item.json.content || '').slice(0, 400).trim()\n  }));\n\nconst articlesText = filtered.length > 0\n  ? filtered.map(i => 'Title: ' + i.title + '\\nURL: ' + i.link + '\\nSnippet: ' + i.contentSnippet).join('\\n\\n---\\n\\n')\n  : 'No articles found this week. Generate placeholder content for a workflow-automation themed issue.';\n\nreturn [{ json: { itemCount: filtered.length, articlesText } }];"
      },
      "id": "filter-articles",
      "name": "Filter Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        384
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.articlesText }}",
        "options": {
          "systemMessage": "You are the editor of StackSignal, a weekly newsletter for indie operators automating their business stacks with n8n and similar tools. You receive a list of recent articles from RSS feeds.\n\nYour task:\n1. Select the 3\u20135 most relevant items for the audience (indie operators, solo devs, SMB owners interested in automation, self-hosting, AI tooling).\n2. Write a one-line take for each \u2014 opinionated, not neutral. The take should reflect the editor's perspective, not a summary.\n3. Suggest 3 subject line options for this week's issue based on the content themes.\n4. Identify the dominant content theme this week (one of: ai-tooling, workflow-automation, self-hosting, indie-business, saas-economics).\n\nRespond with valid JSON only \u2014 no explanation, no markdown, no code fence:\n{\"signal_items\":[{\"title\":\"\",\"url\":\"\",\"take\":\"\"}],\"subject_options\":[\"\",\"\",\"\"],\"theme\":\"\"}",
          "maxIterations": 3,
          "enableStreaming": false
        }
      },
      "id": "ai-agent",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        384
      ]
    },
    {
      "parameters": {
        "modelName": "models/gemini-3.1-flash-lite",
        "options": {
          "maxOutputTokens": 2048,
          "temperature": 0.7
        }
      },
      "id": "gemini-model",
      "name": "Google Gemini Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [
        744,
        608
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nif (!output) throw new Error('No output from AI agent');\nlet parsed;\ntry {\n  const cleaned = output.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  throw new Error('Failed to parse agent JSON: ' + e.message + '. Output was: ' + String(output).slice(0, 300));\n}\nconst si = parsed.signal_items || [];\nconst so = parsed.subject_options || ['StackSignal Draft', 'StackSignal Draft', 'StackSignal Draft'];\nconst theme = parsed.theme || 'workflow-automation';\nconst signalHtml = si.map(i => '<p><strong>' + i.title + '</strong> \u2014 <a href=\"' + i.url + '\">' + i.url + '</a><br><em>' + i.take + '</em></p>').join('\\n');\nconst content = '<h2>\u2699\ufe0f THE WORKFLOW</h2>\\n<p>[Draft here \u2014 550\u2013650 words]</p>\\n<hr>\\n<h2>\ud83d\udd27 THE STACK MOVE</h2>\\n<p>[Draft here \u2014 220\u2013270 words]</p>\\n<hr>\\n<h2>\ud83d\udce1 THE SIGNAL</h2>\\n' + signalHtml;\nconst slackMessage = '\ud83d\udcdd *StackSignal draft ready*\\n\\n*Theme:* ' + theme + '\\n\\n*Subject options:*\\n1. ' + so[0] + '\\n2. ' + so[1] + '\\n3. ' + so[2] + '\\n\\n*Signal items:* ' + si.length + ' pre-populated\\n\\n\u2192 Open Beehiiv to write Workflow + Stack Move sections';\nreturn [{ json: { signal_items: si, subject_options: so, theme, beehiivTitle: so[0] + ' [DRAFT]', beehiivSubtitle: 'Theme: ' + theme + ' | Options: ' + so.join(' / '), beehiivContent: content, slackMessage } }];"
      },
